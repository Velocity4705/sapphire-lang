# Test Math Library
print("Testing Math Library:")
print("sqrt(16) =", math_sqrt(16.0))
print("sin(π/2) =", math_sin(math_pi() / 2.0))
print("cos(0) =", math_cos(0.0))
print("abs(-5.5) =", math_abs(-5.5))
