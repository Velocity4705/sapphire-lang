print("ceil(3.2) =", math_ceil(3.2))
print("π =", math_pi())
print("e =", math_e())
print("")

# Test Dynamic Arrays
print("Testing Dynamic Arrays:")
let arr = array_create()
print("Created array")

array_push(arr, 10)
array_push(arr, 20)
array_push(arr, 30)
print("Pushed 3 elements")

print("Array size:", array_size(arr))
print("Element 0:", array_get(arr, 0))
print("Element 1:", array_get(arr, 1))
print("Element 2:", array_get(arr, 2))
print("")

