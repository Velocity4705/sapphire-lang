import random
import plotting
print("=== Milestone 3: Display Test ===")

print("1. Creating and displaying a quick plot")
let y_data = [1, 4, 2, 8, 5, 7, 3, 9, 6]
let plot1 = quick_plot(y_data, "Sample Data Visualization")
plot_show(plot1)

print("2. Creating and displaying a scatter plot")
let x_data = [1, 2, 3, 4, 5]
let y_scatter = [2, 4, 1, 8, 3]
let plot2 = quick_scatter(x_data, y_scatter, "X vs Y Relationship")
plot_show(plot2)

print("3. Creating and displaying a histogram")
random_seed(123)
let hist_data = []
let i = 0
while i < 20 {
    hist_data.push(random_normal(50.0, 10.0))
    i = i + 1
}

let plot3 = quick_histogram(hist_data, 5, "Normal Distribution Sample")
plot_show(plot3)

print("Display test complete!")