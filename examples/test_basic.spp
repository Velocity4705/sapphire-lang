# Basic Sapphire test

# Variables
let x = 42
let y = 10
let z = x + y
print(z)

# Arithmetic
let a = 5 * 3
let b = 20 / 4
print(a)
print(b)

# Comparisons
let is_large = x > 40
print(is_large)

let is_equal = a == 15
print(is_equal)

# More arithmetic
let product = x * y
print(product)

let quotient = x / y
print(quotient)
