# Sapphire Demo

# Variables and arithmetic
let x = 10
let y = 20
let sum = x + y
print(sum)

# More operations
let product = x * y
let power = 2 ** 8
print(product)
print(power)

# Comparisons
let is_greater = x > 5
print(is_greater)

# Simple conditional
if x > 15:
    print("x is greater than 15")

if x < 15:
    print("x is less than 15")

print("Demo complete!")
