# =============================================================================
# 6. REAL-WORLD DATA ANALYSIS EXAMPLE
# =============================================================================
print("=== 6. REAL-WORLD DATA ANALYSIS ===")

print("• Simulating sales data analysis:")

# Create sample sales data
let sales_data = [100, 150, 120, 180, 200, 175, 160, 190, 210, 185]
let months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct"]

print("  Monthly sales data:")
let i = 0
while i < 10:
    print("  ", months[i], ":", sales_data[i])
    i = i + 1

# Calculate statistics
print("• Statistical analysis:")
let total = 0
i = 0
while i < 10:
    total = total + sales_data[i]
    i = i + 1

let mean = total / 10.0
print("  Total sales:", total)
print("  Average sales:", mean)

# Find min and max
let min_sales = sales_data[0]
let max_sales = sales_data[0]
i = 1
while i < 10:
    if sales_data[i] < min_sales:
        min_sales = sales_data[i]
    if sales_data[i] > max_sales:
        max_sales = sales_data[i]
    i = i + 1

print("  Minimum sales:", min_sales)
print("  Maximum sales:", max_sales)

# Calculate variance and standard deviation
let variance_sum = 0.0
i = 0
while i < 10:
    let diff = sales_data[i] - mean
    variance_sum = variance_sum + (diff * diff)
    i = i + 1

let variance = variance_sum / 10.0
let std_dev = math_sqrt(variance)
print("  Variance:", variance)
print("  Standard deviation:", std_dev)

print("✓ Data analysis complete")
print("")

# =============================================================================
# 7. PERFORMANCE DEMONSTRATION
# =============================================================================
print("=== 7. PERFORMANCE DEMONSTRATION ===")

print("• Large array operations:")
let large_array = array_create()
let count = 1000
let i = 0
while i < count:
    array_push(large_array, i * i)
    i = i + 1

print("  Created and filled", count, "element array")
print("  Array size:", array_size(large_array))

# Calculate sum for verification
let sum = 0
i = 0
while i < array_size(large_array):
    sum = sum + array_get(large_array, i)
    i = i + 1

print("  Sum of squares:", sum)
print("✓ Performance test complete")
print("")

