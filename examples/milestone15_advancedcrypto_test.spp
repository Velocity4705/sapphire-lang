import advancedcrypto

print("=== M15: Advanced Cryptography ===")
print("")

print("--- Post-Quantum: Kyber-768 ---")
let kp = kyber_keygen(768)
let pub = kyber_public_key(kp)
let sec = kyber_secret_key(kp)
print("Public key: " + pub)
let enc = kyber_encapsulate(pub, 768)
let ct  = kyber_ciphertext(enc)
let ss1 = kyber_shared_secret(enc)
let ss2 = kyber_decapsulate(sec, ct, 768)
print("Encap secret: " + ss1)
print("Decap secret: " + ss2)
kyber_destroy_encap(enc)
kyber_destroy_keypair(kp)
print("")

print("--- Post-Quantum: SPHINCS+ ---")
let skp  = sphincs_keygen("sha2-128s")
let spub = sphincs_public_key(skp)
let ssec = sphincs_secret_key(skp)
let sig  = sphincs_sign(ssec, "Hello Sapphire", "sha2-128s")
let ok   = sphincs_verify(spub, "Hello Sapphire", sig, "sha2-128s")
print("Signature valid: " + ok)
sphincs_destroy_keypair(skp)
print("")

print("--- Post-Quantum: McEliece ---")
let mkp  = mceliece_keygen(3488, 2720, 64)
let mpub = mceliece_public_key(mkp)
let msec = mceliece_secret_key(mkp)
let mct  = mceliece_encrypt(mpub, "deadbeef")
let mpt  = mceliece_decrypt(msec, mct)
print("Decrypted: " + mpt)
mceliece_destroy_keypair(mkp)
print("")

print("--- Post-Quantum: Rainbow ---")
let rkp  = rainbow_keygen("I")
let rpub = rainbow_public_key(rkp)
let rsec = rainbow_secret_key(rkp)
let rsig = rainbow_sign(rsec, "test message", "I")
let rok  = rainbow_verify(rpub, "test message", rsig, "I")
print("Signature valid: " + rok)
rainbow_destroy_keypair(rkp)
print("")

print("--- ZK Proofs: zk-SNARK ---")
let zkeys  = zksnark_setup("x^2 + y^2 = z^2")
let zpk    = zksnark_proving_key(zkeys)
let zvk    = zksnark_verification_key(zkeys)
let zcid   = zksnark_circuit_id(zkeys)
let zproof = zksnark_prove(zpk, "private:3,4", "public:5", zcid)
let zph    = zksnark_proof_hex(zproof)
let zok    = zksnark_verify(zvk, zph, "public:5", zcid)
print("SNARK valid: " + zok)
zksnark_destroy_proof(zproof)
zksnark_destroy_keys(zkeys)
print("")

print("--- ZK Proofs: zk-STARK ---")
let stproof = zkstark_prove("trace:fibonacci", 80)
let stph    = zkstark_proof_hex(stproof)
let stok    = zkstark_verify(stph, "fib:55", 80)
print("STARK valid: " + stok)
zkstark_destroy_proof(stproof)
print("")

print("--- ZK Proofs: Bulletproofs ---")
let bproof = bulletproof_prove_range(42, 64)
let bph    = bulletproof_proof_hex(bproof)
let bch    = bulletproof_commitment_hex(bproof)
let bok    = bulletproof_verify_range(bph, bch, 64)
print("Bulletproof valid: " + bok)
bulletproof_destroy(bproof)
print("")

print("--- ZK Proofs: PLONK ---")
let psrs   = plonk_setup(1024)
let psrsh  = plonk_srs_hex(psrs)
let psrsid = plonk_srs_id(psrs)
let pproof = plonk_prove(psrsh, "circuit:add", "witness:3+4=7", psrsid)
let ppok   = plonk_verify(psrsh, plonk_proof_hex(pproof), "public:7", psrsid)
print("PLONK valid: " + ppok)
plonk_destroy_proof(pproof)
plonk_destroy_srs(psrs)
print("")

print("--- Homomorphic Encryption: BGV ---")
let bgvctx = bgv_create_context(65537, 4096)
let bgvcid = bgv_context_id(bgvctx)
let bgvkp  = bgv_keygen(bgvcid)
let bgvpub = bgv_public_key(bgvkp)
let bgvsec = bgv_secret_key(bgvkp)
let bgvct1 = bgv_encrypt(bgvpub, bgvcid, 7)
let bgvct2 = bgv_encrypt(bgvpub, bgvcid, 3)
let bgvsum = bgv_add(bgv_ciphertext_hex(bgvct1), bgv_ciphertext_hex(bgvct2), bgvcid)
let bgvres = bgv_decrypt(bgvsec, bgvcid, bgv_ciphertext_hex(bgvsum))
print("BGV 7+3 = " + bgvres)
bgv_destroy_ciphertext(bgvct1)
bgv_destroy_ciphertext(bgvct2)
bgv_destroy_ciphertext(bgvsum)
bgv_destroy_keypair(bgvkp)
bgv_destroy_context(bgvctx)
print("")

print("--- Homomorphic Encryption: CKKS ---")
let cctx = ckks_create_context(8192, 40)
let ccid = ckks_context_id(cctx)
let ckp  = ckks_keygen(ccid)
let cpub = ckks_public_key(ckp)
let csec = ckks_secret_key(ckp)
let cct1 = ckks_encrypt(cpub, ccid, 3.14)
let cct2 = ckks_encrypt(cpub, ccid, 2.71)
let csum = ckks_add(ckks_ciphertext_hex(cct1), ckks_ciphertext_hex(cct2), ccid)
let cres = ckks_decrypt(csec, ccid, ckks_ciphertext_hex(csum))
print("CKKS 3.14+2.71 = " + cres)
ckks_destroy_ciphertext(cct1)
ckks_destroy_ciphertext(cct2)
ckks_destroy_ciphertext(csum)
ckks_destroy_keypair(ckp)
ckks_destroy_context(cctx)
print("")

print("--- Homomorphic Encryption: TFHE ---")
let tctx   = tfhe_create_context(128)
let tcid   = tfhe_context_id(tctx)
let tkp    = tfhe_keygen(tcid)
let tsec   = tfhe_secret_key(tkp)
let tcloud = tfhe_cloud_key(tkp)
let tb1    = tfhe_encrypt_bit(tsec, tcid, 1)
let tb0    = tfhe_encrypt_bit(tsec, tcid, 0)
let tand   = tfhe_gate_and(tfhe_ciphertext_hex(tb1), tfhe_ciphertext_hex(tb0), tcloud, tcid)
let tandr  = tfhe_decrypt_bit(tsec, tcid, tfhe_ciphertext_hex(tand))
print("TFHE 1 AND 0 = " + tandr)
let tor    = tfhe_gate_or(tfhe_ciphertext_hex(tb1), tfhe_ciphertext_hex(tb0), tcloud, tcid)
let torr   = tfhe_decrypt_bit(tsec, tcid, tfhe_ciphertext_hex(tor))
print("TFHE 1 OR 0 = " + torr)
tfhe_destroy_ciphertext(tb1)
tfhe_destroy_ciphertext(tb0)
tfhe_destroy_ciphertext(tand)
tfhe_destroy_ciphertext(tor)
tfhe_destroy_keypair(tkp)
tfhe_destroy_context(tctx)
print("")

print("--- Shamir Secret Sharing (3-of-5) ---")
let shares    = shamir_split(123456789, 5, 3)
let n         = shamir_share_count(shares)
print("Shares: " + n)
let recovered = shamir_reconstruct(shares, 3)
print("Recovered: " + recovered)
shamir_destroy_shares(shares)
print("")

print("--- Secure MPC ---")
let smpc = smpc_share(999, 3, 2)
let sc   = smpc_share_count(smpc)
print("SMPC shares: " + sc)
let srec = smpc_reconstruct(smpc, 3)
print("Reconstructed: " + srec)
smpc_destroy_shares(smpc)
print("")

print("--- Threshold Cryptography (2-of-3) ---")
let thr  = threshold_keygen(2, 3)
let tpub = threshold_public_key(thr)
print("Threshold pubkey: " + tpub)
let ps0  = threshold_partial_sign(threshold_share_hex(thr, 0), "vote:yes", 0)
let ps1  = threshold_partial_sign(threshold_share_hex(thr, 1), "vote:yes", 1)
let csig = threshold_combine(ps0 + "," + ps1, tpub, 2)
let tvok = threshold_verify(tpub, "vote:yes", csig)
print("Threshold sig valid: " + tvok)
threshold_destroy(thr)
print("")

print("--- Oblivious Transfer ---")
let sender   = ot_sender_init("secret_message_0", "secret_message_1")
let sstate   = ot_sender_state(sender)
let receiver = ot_receiver_init(1)
let rquery   = ot_receiver_query(receiver)
let otmsg    = ot_sender_respond(sstate, rquery)
let omhex    = ot_message_hex(otmsg)
let result   = ot_receiver_extract(rquery, omhex, 1)
print("OT result (choice=1): " + result)
ot_destroy_message(otmsg)
ot_destroy_receiver(receiver)
ot_destroy_sender(sender)
print("")

print("=== M15 Advanced Cryptography: COMPLETE ===")
