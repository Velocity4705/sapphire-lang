


print("=== Hash Map Literal Test ===")


let map1 = {"name": "Alice", "age": 30, "city": "New York"}
print("map1:", map1)


let map2 = {}
print("map2:", map2)


let map3 = {"string": "hello", "number": 42, "boolean": true}
print("map3:", map3)

print("\n=== Hash Map Methods Test ===")


print("map1.get('name'):", map1.get("name"))
print("map1.get('age'):", map1.get("age"))
print("map1.get('missing'):", map1.get("missing"))


map1.set("country", "USA")
print("After setting country:", map1)


print("map1.has('name'):", map1.has("name"))
print("map1.has('missing'):", map1.has("missing"))


print("map1.size:", map1.size)
print("map1.length:", map1.length)


let keys = map1.keys()
print("map1.keys():", keys)


let values = map1.values()
print("map1.values():", values)


let removed = map1.remove("age")
print("Removed value:", removed)
print("After removing age:", map1)


let dynamic_map = {}
dynamic_map.set("key1", "value1")
dynamic_map.set("key2", 100)
dynamic_map.set("key3", [1, 2, 3])
print("Dynamic map:", dynamic_map)

print("\n=== Hash Map Integration Test ===")


let complex_map = {"users": ["Alice", "Bob", "Charlie"], "scores": [95, 87, 92], "active": true}
print("Complex map:", complex_map)


let user_list = complex_map.get("users")
user_list.push("David")
print("After adding user:", complex_map)

print("\n=== Hash Map Success ===")
print("All hash map tests completed successfully!")