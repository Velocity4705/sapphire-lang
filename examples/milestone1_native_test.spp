# 5. DATA PROCESSING - Real data science example
print("5. Data Processing Example:")

# Sales data for analysis
let sales = [120, 150, 180, 200, 175, 160, 190, 210, 185, 195]
print("  Sales data:", sales)
print("  Number of months:", len(sales))

# Calculate total and average
let total = 0
let i = 0
while i < len(sales):
    total = total + sales[i]
    i = i + 1

let average = total / len(sales)
print("  Total sales:", total)
print("  Average sales:", average)

# Find min and max
let min_sales = sales[0]
let max_sales = sales[0]
i = 1
while i < len(sales):
    if sales[i] < min_sales:
        min_sales = sales[i]
    if sales[i] > max_sales:
        max_sales = sales[i]
    i = i + 1

print("  Min sales:", min_sales)
print("  Max sales:", max_sales)
print("  Range:", max_sales - min_sales)

print("")

