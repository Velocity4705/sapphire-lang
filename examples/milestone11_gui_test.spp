import gui

# ===== Phase 1: Text Rendering =====
print("=== Phase 1: Text Rendering ===")

fm = gui_font_manager_create()
font1 = gui_font_load(fm, "Arial", 16, "normal")
font2 = gui_font_load(fm, "Roboto", 24, "bold")

print("Font manager count:")
print(gui_font_manager_count(fm))

print("Font 1 name:")
print(gui_font_name(font1))
print("Font 1 size:")
print(gui_font_size(font1))
print("Font 2 style:")
print(gui_font_style(font2))

tr = gui_text_renderer_create()
gui_text_renderer_set_font(tr, font1)
gui_text_renderer_set_color(tr, 1.0, 1.0, 1.0, 1.0)
gui_text_renderer_set_align(tr, "center")
gui_text_renderer_set_antialias(tr, 1)

result = gui_text_renderer_render(tr, "Hello\nWorld")
print("Render result:")
print(result)
print("Line count:")
print(gui_text_renderer_line_count(tr))
print("Line 0:")
print(gui_text_renderer_line_at(tr, 0))
print("Line 1:")
print(gui_text_renderer_line_at(tr, 1))

tm = gui_text_metrics_measure(font2, "Hello World")
print("Text width:")
print(gui_text_metrics_width(tm))
print("Text height:")
print(gui_text_metrics_height(tm))
print("Ascent:")
print(gui_text_metrics_ascent(tm))
print("Descent:")
print(gui_text_metrics_descent(tm))
print("Line height:")
print(gui_text_metrics_line_height(tm))

gui_text_metrics_destroy(tm)
gui_text_renderer_destroy(tr)
gui_font_manager_destroy(fm)
print("Phase 1 OK")

# ===== Phase 2: Mouse Support =====
print("=== Phase 2: Mouse Support ===")

mh = gui_mouse_handler_create()
gui_mouse_handler_press(mh, 100, 200, 0)
gui_mouse_handler_move(mh, 110, 205)
gui_mouse_handler_click(mh, 110, 205, 0)
gui_mouse_handler_release(mh, 110, 205, 0)
gui_mouse_handler_scroll(mh, 110, 205, 3)

print("Event count:")
print(gui_mouse_handler_event_count(mh))
print("Event 0 type:")
print(gui_mouse_handler_event_type(mh, 0))
print("Event 2 type:")
print(gui_mouse_handler_event_type(mh, 2))
print("Cursor X:")
print(gui_mouse_handler_cursor_x(mh))
print("Cursor Y:")
print(gui_mouse_handler_cursor_y(mh))
print("Button 0 down:")
print(gui_mouse_handler_is_button_down(mh, 0))

dd = gui_drag_drop_create()
gui_drag_drop_start(dd, 50, 60, "file.txt", "text/plain")
print("Is dragging:")
print(gui_drag_drop_is_dragging(dd))
print("Drag data:")
print(gui_drag_drop_data(dd))
print("Drag mime:")
print(gui_drag_drop_mime(dd))
gui_drag_drop_move(dd, 80, 90)
dropped = gui_drag_drop_drop(dd, 200, 200)
print("Dropped:")
print(dropped)
print("Is dragging after drop:")
print(gui_drag_drop_is_dragging(dd))

cm = gui_context_menu_create()
gui_context_menu_add_item(cm, "Cut", "cut")
gui_context_menu_add_item(cm, "Copy", "copy")
gui_context_menu_add_separator(cm)
gui_context_menu_add_item(cm, "Paste", "paste")
gui_context_menu_show(cm, 300, 150)

print("Context menu item count:")
print(gui_context_menu_item_count(cm))
print("Item 0 label:")
print(gui_context_menu_item_label(cm, 0))
print("Item 2 label:")
print(gui_context_menu_item_label(cm, 2))
print("Item 3 action:")
print(gui_context_menu_item_action(cm, 3))
print("Menu visible:")
print(gui_context_menu_is_visible(cm))
print("Menu X:")
print(gui_context_menu_x(cm))

gui_context_menu_hide(cm)
print("Menu visible after hide:")
print(gui_context_menu_is_visible(cm))

gui_context_menu_destroy(cm)
gui_drag_drop_destroy(dd)
gui_mouse_handler_destroy(mh)
print("Phase 2 OK")

# ===== Phase 3: Advanced Widgets =====
print("=== Phase 3: Advanced Widgets ===")

ti = gui_text_input_create()
gui_text_input_set_placeholder(ti, "Enter text...")
gui_text_input_set_max_length(ti, 100)
gui_text_input_focus(ti)
gui_text_input_insert(ti, "Hello")
gui_text_input_insert(ti, " World")
print("Text input value:")
print(gui_text_input_text(ti))
print("Length:")
print(gui_text_input_length(ti))
print("Focused:")
print(gui_text_input_is_focused(ti))
gui_text_input_blur(ti)
print("Focused after blur:")
print(gui_text_input_is_focused(ti))
gui_text_input_clear(ti)
print("After clear:")
print(gui_text_input_length(ti))

pw = gui_text_input_create()
gui_text_input_set_password(pw, 1)
gui_text_input_set_text(pw, "secret123")
print("Password length:")
print(gui_text_input_length(pw))

ml = gui_text_input_create()
gui_text_input_set_multiline(ml, 1)
gui_text_input_set_text(ml, "Line one")
print("Multiline text:")
print(gui_text_input_text(ml))

gui_text_input_destroy(ti)
gui_text_input_destroy(pw)
gui_text_input_destroy(ml)

drp = gui_dropdown_create()
gui_dropdown_set_placeholder(drp, "Select language...")
gui_dropdown_add_option(drp, "Sapphire", "spp")
gui_dropdown_add_option(drp, "Python", "py")
gui_dropdown_add_option(drp, "Rust", "rs")
gui_dropdown_add_option(drp, "Go", "go")
print("Dropdown option count:")
print(gui_dropdown_option_count(drp))
print("Option 0 label:")
print(gui_dropdown_option_label(drp, 0))
print("Option 2 value:")
print(gui_dropdown_option_value(drp, 2))
gui_dropdown_set_selected(drp, 1)
print("Selected index:")
print(gui_dropdown_selected_index(drp))
print("Selected value:")
print(gui_dropdown_selected_value(drp))
gui_dropdown_open(drp)
print("Is open:")
print(gui_dropdown_is_open(drp))
gui_dropdown_close(drp)
print("Is open after close:")
print(gui_dropdown_is_open(drp))
gui_dropdown_destroy(drp)

tbl = gui_table_create()
gui_table_add_column(tbl, "Name", 150)
gui_table_add_column(tbl, "Score", 80)
gui_table_add_column(tbl, "Grade", 60)
gui_table_add_row(tbl)
gui_table_set_cell(tbl, 0, 0, "Alice")
gui_table_set_cell(tbl, 0, 1, "95")
gui_table_set_cell(tbl, 0, 2, "A")
gui_table_add_row(tbl)
gui_table_set_cell(tbl, 1, 0, "Bob")
gui_table_set_cell(tbl, 1, 1, "82")
gui_table_set_cell(tbl, 1, 2, "B")
gui_table_add_row(tbl)
gui_table_set_cell(tbl, 2, 0, "Carol")
gui_table_set_cell(tbl, 2, 1, "91")
gui_table_set_cell(tbl, 2, 2, "A")
print("Table rows:")
print(gui_table_row_count(tbl))
print("Table cols:")
print(gui_table_col_count(tbl))
print("Cell 0,0:")
print(gui_table_get_cell(tbl, 0, 0))
print("Column header 1:")
print(gui_table_column_header(tbl, 1))
print("Column width 0:")
print(gui_table_column_width(tbl, 0))
gui_table_set_selected_row(tbl, 1)
print("Selected row:")
print(gui_table_selected_row(tbl))
gui_table_sort_by_column(tbl, 0, 1)
print("After sort, cell 0,0:")
print(gui_table_get_cell(tbl, 0, 0))
csv = gui_table_to_csv(tbl)
print("CSV first line:")
print(csv)
gui_table_destroy(tbl)

tv = gui_tree_view_create()
root = gui_tree_view_add_node(tv, -1, "Root", "root_data")
child1 = gui_tree_view_add_node(tv, root, "Child 1", "c1_data")
child2 = gui_tree_view_add_node(tv, root, "Child 2", "c2_data")
leaf = gui_tree_view_add_node(tv, child1, "Leaf", "leaf_data")
print("Tree node count:")
print(gui_tree_view_node_count(tv))
print("Root label:")
print(gui_tree_view_node_label(tv, root))
print("Child1 parent:")
print(gui_tree_view_node_parent(tv, child1))
print("Root child count:")
print(gui_tree_view_child_count(tv, root))
gui_tree_view_expand(tv, root)
print("Root expanded:")
print(gui_tree_view_node_is_expanded(tv, root))
gui_tree_view_select(tv, child2)
print("Selected node:")
print(gui_tree_view_selected_node(tv))
print("Leaf data:")
print(gui_tree_view_node_data(tv, leaf))
gui_tree_view_destroy(tv)

tabs = gui_tabs_create()
gui_tabs_add_tab(tabs, "Editor", "editor_panel")
gui_tabs_add_tab(tabs, "Terminal", "terminal_panel")
gui_tabs_add_tab(tabs, "Output", "output_panel")
print("Tab count:")
print(gui_tabs_count(tabs))
print("Tab 0 label:")
print(gui_tabs_label(tabs, 0))
print("Tab 1 content id:")
print(gui_tabs_content_id(tabs, 1))
gui_tabs_set_active(tabs, 2)
print("Active index:")
print(gui_tabs_active_index(tabs))
print("Active label:")
print(gui_tabs_active_label(tabs))
gui_tabs_remove_tab(tabs, 0)
print("Tab count after remove:")
print(gui_tabs_count(tabs))
gui_tabs_destroy(tabs)
print("Phase 3 OK")

# ===== Phase 4: Layout Management =====
print("=== Phase 4: Layout Management ===")

fl = gui_flex_layout_create("row")
gui_flex_layout_set_gap(fl, 8)
gui_flex_layout_set_padding(fl, 16)
gui_flex_layout_set_align(fl, "center")
gui_flex_layout_set_justify(fl, "start")
gui_flex_layout_add_item(fl, "sidebar", 1, 200, 300)
gui_flex_layout_add_item(fl, "main", 3, 400, 0)
gui_flex_layout_add_item(fl, "panel", 1, 150, 250)
print("Flex item count:")
print(gui_flex_layout_item_count(fl))
print("Item 0 id:")
print(gui_flex_layout_item_id(fl, 0))
print("Item 1 flex:")
print(gui_flex_layout_item_flex(fl, 1))
print("Direction:")
print(gui_flex_layout_direction(fl))
result = gui_flex_layout_compute(fl, 1200, 800)
print("Flex compute result:")
print(result)
gui_flex_layout_destroy(fl)

gl = gui_grid_layout_create(3, 2)
gui_grid_layout_set_gap(gl, 10)
gui_grid_layout_set_col_width(gl, 0, 200)
gui_grid_layout_set_row_height(gl, 0, 100)
gui_grid_layout_place(gl, "header", 0, 0, 3, 1)
gui_grid_layout_place(gl, "nav", 0, 1, 1, 1)
gui_grid_layout_place(gl, "content", 1, 1, 2, 1)
print("Grid cols:")
print(gui_grid_layout_cols(gl))
print("Grid rows:")
print(gui_grid_layout_rows(gl))
print("Grid item count:")
print(gui_grid_layout_item_count(gl))
print("Grid item 0 id:")
print(gui_grid_layout_item_id(gl, 0))
result = gui_grid_layout_compute(gl, 900, 600)
print("Grid compute result:")
print(result)
gui_grid_layout_destroy(gl)

al = gui_anchor_layout_create()
gui_anchor_layout_add_item(al, "toolbar", 0, 0, 800, 40)
gui_anchor_layout_add_item(al, "sidebar", 0, 40, 200, 560)
gui_anchor_layout_add_item(al, "main", 200, 40, 600, 560)
gui_anchor_layout_set_anchor(al, "toolbar", "right", 0)
gui_anchor_layout_set_anchor(al, "main", "right", 0)
gui_anchor_layout_set_anchor(al, "main", "bottom", 0)
print("Anchor item count:")
print(gui_anchor_layout_item_count(al))
print("Anchor item 0 id:")
print(gui_anchor_layout_item_id(al, 0))
result = gui_anchor_layout_compute(al, 1024, 768)
print("Anchor compute result:")
print(result)
gui_anchor_layout_destroy(al)
print("Phase 4 OK")

print("=== Milestone 11 GUI Complete ===")
