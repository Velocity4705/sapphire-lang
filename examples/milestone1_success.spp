# 1. Dynamic Arrays ✅
print("1. Dynamic Arrays:")
let data = [1, 2, 3]
print("   • Array literals:", data)
print("   • Array indexing:", data[0])
data[0] = 10
print("   • Array assignment:", data)
data.push(4)
print("   • Array push:", data)
let popped = data.pop()
print("   • Array pop:", popped, "->", data)
print("   • Array length:", data.length)

print("")

# 2. String Operations ✅
print("2. String Operations:")
let text = "Hello World"
print("   • String literals:", text)
print("   • String length:", text.length)
print("   • String upper:", text.upper())
print("   • String lower:", text.lower())
let words = text.split(" ")
print("   • String split:", words)

print("")

# 3. Mathematical Functions ✅
print("3. Mathematical Functions:")
print("   • Square root:", math_sqrt(16.0))
print("   • Power:", math_pow(2.0, 8.0))
print("   • Trigonometry:", math_sin(math_pi() / 2.0))
print("   • Logarithm:", math_log(math_e()))

print("")

# 4. Data Science Example ✅
print("4. Data Science Analysis:")
let sales = [100, 150, 200, 175, 225]
print("   • Dataset:", sales)

let total = 0
let i = 0
while i < sales.length:
    total = total + sales[i]
    i = i + 1

let mean = total / sales.length
print("   • Total:", total)
print("   • Average:", mean)

print("")

# 5. Floating-Point Operations ✅
print("5. Floating-Point Operations:")
let pi = 3.14159
let radius = 2.5
let area = pi * radius * radius
print("   • Circle area (π × r²):", area)
print("   • Mixed operations:", 10 + 3.5 * 2.0)

print("")

