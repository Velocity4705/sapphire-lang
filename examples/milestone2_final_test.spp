print("=== Milestone 2 - Final Comprehensive Test ===")

print("\n1. Hash Maps - Complete Implementation")
let user_map = {"name": "Alice", "age": 30, "active": true}
print("User map:", user_map)
print("Name:", user_map.get("name"))
print("Age:", user_map.get("age"))
print("Has email:", user_map.has("email"))

user_map.set("email", "alice@example.com")
user_map.set("score", 95.5)
print("After updates:", user_map)
print("All keys:", user_map.keys())
print("All values:", user_map.values())
print("Map size:", user_map.size)

let removed = user_map.remove("active")
print("Removed 'active':", removed)
print("Final map:", user_map)

print("\n2. JSON Support - Parse, Stringify, Objects")
let json_obj = json_create_object()
json_set(json_obj, "product", "Sapphire Language")
json_set(json_obj, "version", "2.0")
json_set(json_obj, "stable", true)
json_set(json_obj, "downloads", 10000)

print("JSON object (compact):", json_stringify(json_obj, false))
print("JSON object (pretty):")
print(json_stringify(json_obj, true))

let json_string = "{\"language\": \"Sapphire\", \"year\": 2026, \"fast\": true}"
let parsed_json = json_parse(json_string)
print("Parsed JSON:", json_stringify(parsed_json, true))

print("\n3. Random Numbers - All Distributions")
random_seed(42)
print("Seeded random numbers (reproducible):")
print("- Uniform [0,1):", random())
print("- Uniform [0,1):", random())
print("- Range [10,20]:", random(10.0, 20.0))
print("- Integer [1,6]:", random_int(1, 6))
print("- Integer [1,6]:", random_int(1, 6))
print("- Normal (μ=0, σ=1):", random_normal())
print("- Normal (μ=100, σ=15):", random_normal(100.0, 15.0))
print("- Boolean (50%):", random_boolean())
print("- Boolean (80%):", random_boolean(0.8))

print("\nCryptographic random (non-reproducible):")
print("- Crypto uniform:", crypto_random())
print("- Crypto integer [1,100]:", crypto_random_int(1, 100))

print("\n4. Integration Example - Data Analysis")
let data_points = {}
data_points.set("sample_1", random_normal(100.0, 10.0))
data_points.set("sample_2", random_normal(100.0, 10.0))
data_points.set("sample_3", random_normal(100.0, 10.0))

print("Data points:", data_points)

let analysis = json_create_object()
json_set(analysis, "samples", data_points.size)
json_set(analysis, "method", "normal_distribution")
json_set(analysis, "parameters", "mean=100, stddev=10")

print("Analysis report:")
print(json_stringify(analysis, true))

print("\n5. Performance Test - Large Hash Map")
let large_map = {}
let i = 0
while i < 1000 {
    let key = "key_" + i
    large_map.set(key, random_int(1, 1000))
    i = i + 1
}
print("Large map created with", large_map.size, "entries")
print("Sample value:", large_map.get("key_500"))

