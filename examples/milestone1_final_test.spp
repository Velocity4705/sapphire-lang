# 3. REAL DATA SCIENCE WORKFLOW ✅
print("3. Complete Data Science Workflow:")

# Load and process data
let sales_data = [120, 150, 180, 200, 175, 160, 190, 210, 185, 195]
print("  Raw sales data:", sales_data)

# Data cleaning - fix outliers
if sales_data[0] < 130:
    sales_data[0] = 130  # Correct low value

sales_data.push(220)  # Add new month
sales_data.push(205)  # Add another month
print("  Cleaned and extended data:", sales_data)
print("  Dataset size:", sales_data.length)

# Statistical analysis
let total = 0
let i = 0
while i < sales_data.length:
    total = total + sales_data[i]
    i = i + 1

let mean = total / sales_data.length
print("  Total sales:", total)
print("  Average sales:", mean)

# Find extremes
let min_val = sales_data[0]
let max_val = sales_data[0]
i = 1
while i < sales_data.length:
    if sales_data[i] < min_val:
        min_val = sales_data[i]
    if sales_data[i] > max_val:
        max_val = sales_data[i]
    i = i + 1

print("  Min sales:", min_val)
print("  Max sales:", max_val)
print("  Range:", max_val - min_val)

# Calculate standard deviation
let variance_sum = 0.0
i = 0
while i < sales_data.length:
    let diff = sales_data[i] - mean
    variance_sum = variance_sum + (diff * diff)
    i = i + 1

let variance = variance_sum / sales_data.length
let std_dev = math_sqrt(variance)
print("  Standard deviation:", std_dev)

print("")

# 4. TEXT PROCESSING EXAMPLE ✅
print("4. Text Processing Example:")
let raw_names = ["  alice  ", "BOB", "charlie"]
print("  Raw names:", raw_names)

# Clean and standardize names
let clean_names = []
i = 0
while i < raw_names.length:
    let name = raw_names[i].lower()
    # Note: trim() not implemented yet, but we have the core functionality
    clean_names.push(name)
    i = i + 1

print("  Cleaned names:", clean_names)

# Create formatted output
let formatted = []
i = 0
while i < clean_names.length:
    let parts = clean_names[i].split("")
    if parts.length > 0:
        # Capitalize first letter (manual implementation)
        let first_char = parts[0].upper()
        let rest = clean_names[i]  # Would use substring in full implementation
        formatted.push(first_char)  # Simplified for demo
    i = i + 1

print("  First letters:", formatted)

print("")

# 5. MATHEMATICAL COMPUTATIONS ✅
print("5. Mathematical Computations:")
let angles = [0.0, math_pi() / 6.0, math_pi() / 4.0, math_pi() / 3.0, math_pi() / 2.0]
print("  Angles (radians):", angles)

let sin_values = []
let cos_values = []
i = 0
while i < angles.length:
    sin_values.push(math_sin(angles[i]))
    cos_values.push(math_cos(angles[i]))
    i = i + 1

print("  Sin values:", sin_values)
print("  Cos values:", cos_values)

# Verify Pythagorean identity: sin²(x) + cos²(x) = 1
print("  Pythagorean identity verification:")
i = 0
while i < angles.length:
    let sin_sq = math_pow(sin_values[i], 2.0)
    let cos_sq = math_pow(cos_values[i], 2.0)
    let sum = sin_sq + cos_sq
    print("    sin²(" + i + ") + cos²(" + i + ") =", sum)
    i = i + 1

print("")

