import security

print("=== Milestone 7: Cybersecurity Platform ===")
print("")

# ===== Phase 1: Vulnerability Scanner =====
print("--- Phase 1: Vulnerability Scanner ---")

scanner = sec_scanner_create()
db_size = sec_scanner_vuln_db_size(scanner)
print("Vuln DB entries:")
print(db_size)

result = sec_scanner_scan_host(scanner, "192.168.1.100", "")
target = sec_scanresult_target(result)
reachable = sec_scanresult_reachable(result)
open_ports = sec_scanresult_open_ports(result)
vuln_count = sec_scanresult_vuln_count(result)

print("Target:")
print(target)
print("Reachable:")
print(reachable)
print("Open ports:")
print(open_ports)
print("Vulnerabilities found:")
print(vuln_count)

port_num = sec_scanresult_port_number(result, 0)
port_svc = sec_scanresult_port_service(result, 0)
print("First port:")
print(port_num)
print("Service:")
print(port_svc)

vuln_name = sec_scanresult_vuln_name(result, 0)
vuln_sev = sec_scanresult_vuln_severity(result, 0)
vuln_fix = sec_scanresult_vuln_remediation(result, 0)
print("First vuln:")
print(vuln_name)
print("Severity:")
print(vuln_sev)
print("Remediation:")
print(vuln_fix)

sec_scanresult_destroy(result)
sec_scanner_destroy(scanner)
print("Phase 1 complete")
print("")
# ===== Phase 2: Web Security Testing =====
print("--- Phase 2: Web Security Testing ---")

tester = sec_web_tester_create()

sqli = sec_web_test_sqli(tester, "http://example.com/login", "id")
xss = sec_web_test_xss(tester, "http://example.com/search", "q")
csrf = sec_web_test_csrf(tester, "http://example.com/transfer")
auth = sec_web_test_auth_bypass(tester, "http://example.com/admin")
pt = sec_web_test_path_traversal(tester, "http://example.com/file", "path")

print("SQLi vulnerable (id param):")
print(sqli)
print("XSS vulnerable (q param):")
print(xss)
print("CSRF vulnerable (transfer):")
print(csrf)
print("Auth bypass (admin):")
print(auth)
print("Path traversal (path param):")
print(pt)

wscan = sec_web_scan(tester, "http://example.com/login?id=1&user=admin")
finding_count = sec_webscan_finding_count(wscan)
print("Web scan findings:")
print(finding_count)

fname = sec_webscan_finding_name(wscan, 0)
fsev = sec_webscan_finding_severity(wscan, 0)
fparam = sec_webscan_finding_param(wscan, 0)
print("First finding:")
print(fname)
print("Severity:")
print(fsev)
print("Parameter:")
print(fparam)

encoded = sec_web_encode_payload(tester, "<script>alert(1)</script>", "url")
print("URL-encoded XSS payload:")
print(encoded)

payloads = sec_web_get_payloads(tester, "sqli")
print("SQLi payloads available:")
print(payloads)

sec_webscan_destroy(wscan)
sec_web_tester_destroy(tester)
print("Phase 2 complete")
print("")
# ===== Phase 3: Malware Analysis =====
print("--- Phase 3: Malware Analysis ---")

analyzer = sec_malware_analyzer_create()

static_r = sec_malware_static_analysis(analyzer, "normal_program.exe", "")
threat = sec_static_result_threat_level(static_r)
ftype = sec_static_result_file_type(static_r)
sha = sec_static_result_sha256(static_r)
entropy = sec_static_result_entropy(static_r)
str_count = sec_static_result_string_count(static_r)
susp_count = sec_static_result_suspicious_count(static_r)

print("Static analysis - threat level:")
print(threat)
print("File type:")
print(ftype)
print("SHA256:")
print(sha)
print("Entropy:")
print(entropy)
print("Strings found:")
print(str_count)
print("Suspicious patterns:")
print(susp_count)

sec_static_result_destroy(static_r)

dyn_r = sec_malware_dynamic_analysis(analyzer, "malware_sample.exe", 3000)
dthreat = sec_dynamic_result_threat_level(dyn_r)
event_count = sec_dynamic_result_event_count(dyn_r)
ioc_count = sec_dynamic_result_ioc_count(dyn_r)

print("Dynamic analysis - threat level:")
print(dthreat)
print("Behavior events:")
print(event_count)
print("Network IOCs:")
print(ioc_count)

etype = sec_dynamic_result_event_type(dyn_r, 0)
etarget = sec_dynamic_result_event_target(dyn_r, 0)
ioc0 = sec_dynamic_result_ioc(dyn_r, 0)
print("First event type:")
print(etype)
print("Event target:")
print(etarget)
print("First IOC:")
print(ioc0)

added = sec_malware_add_yara_rule(analyzer, "custom_rule", "suspicious_string")
print("YARA rule added:")
print(added)

sec_dynamic_result_destroy(dyn_r)
sec_malware_analyzer_destroy(analyzer)
print("Phase 3 complete")
print("")
# ===== Phase 4: Educational CTF Platform =====
print("--- Phase 4: Educational CTF Platform ---")

platform = sec_edu_platform_create()
ch_count = sec_edu_challenge_count(platform)
print("Total challenges:")
print(ch_count)

cid0 = sec_edu_challenge_id(platform, 0)
cname0 = sec_edu_challenge_name(platform, 0)
ccat0 = sec_edu_challenge_category(platform, 0)
cpts0 = sec_edu_challenge_points(platform, 0)
cdesc0 = sec_edu_challenge_description(platform, 0)
chint0 = sec_edu_challenge_hint(platform, 0)

print("Challenge 0 id:")
print(cid0)
print("Name:")
print(cname0)
print("Category:")
print(ccat0)
print("Points:")
print(cpts0)
print("Hint:")
print(chint0)

session = sec_edu_create_session(platform, "hacker42")
player = sec_edu_session_player(session)
print("Player:")
print(player)

ok = sec_edu_session_submit(platform, session, "web-001", "FLAG{sql_injection_master}")
print("Correct flag result:")
print(ok)

score = sec_edu_session_score(session)
print("Score after web-001:")
print(score)

bad = sec_edu_session_submit(platform, session, "web-002", "wrong_flag")
print("Wrong flag result:")
print(bad)

tutorial = sec_edu_get_tutorial(platform, "sql_injection")
print("Tutorial loaded (length > 0):")
print(len(tutorial))

board = sec_edu_leaderboard(platform)
print("Leaderboard:")
print(board)

sec_edu_session_destroy(session)
sec_edu_platform_destroy(platform)
print("Phase 4 complete")
print("")
print("=== Milestone 7 Complete ===")
