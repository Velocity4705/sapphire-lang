# 5. DATA SCIENCE EXAMPLE ✅
print("5. Real Data Science Analysis:")
print("  Dataset: Monthly sales figures")
print("  Data:", sales_data)

# Calculate statistics
let total_sales = 0
let i = 0
while i < len(sales_data):
    total_sales = total_sales + sales_data[i]
    i = i + 1

let mean_sales = total_sales / len(sales_data)
print("  Total sales:", total_sales)
print("  Mean sales:", mean_sales)

# Find min and max
let min_sales = sales_data[0]
let max_sales = sales_data[0]
i = 1
while i < len(sales_data):
    if sales_data[i] < min_sales:
        min_sales = sales_data[i]
    if sales_data[i] > max_sales:
        max_sales = sales_data[i]
    i = i + 1

print("  Min sales:", min_sales)
print("  Max sales:", max_sales)
print("  Range:", max_sales - min_sales)

# Calculate variance and standard deviation
let variance_sum = 0.0
i = 0
while i < len(sales_data):
    let diff = sales_data[i] - mean_sales
    variance_sum = variance_sum + (diff * diff)
    i = i + 1

let variance = variance_sum / len(sales_data)
let std_dev = math_sqrt(variance)
print("  Variance:", variance)
print("  Standard deviation:", std_dev)

print("")

