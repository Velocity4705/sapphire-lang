// Pong Game - Classic arcade game using SDL2
// Demonstrates: game loop, input handling, collision detection, rendering

import graphics.sdl2

fn main() {
    print("=== Pong Game ===")
    print("Controls:")
    print("  W/S: Left paddle")
    print("  Up/Down: Right paddle")
    print("  ESC: Quit")
    print()
    
    // Create window
    let window = sapphire_sdl2_create_window("Pong", 800, 600)
    sapphire_sdl2_show_window(window)
    
    // Game state
    let paddle1_y = 250
    let paddle2_y = 250
    let ball_x = 400
    let ball_y = 300
    let ball_dx = 3
    let ball_dy = 3
    let score1 = 0
    let score2 = 0
    
    // Game constants
    let paddle_width = 15
    let paddle_height = 100
    let ball_size = 15
    let paddle_speed = 5
    
    // Game loop
    let running = true
    while running {
        sapphire_sdl2_poll_events(window)
        
        // Check for quit
        if sapphire_sdl2_should_close(window) {
            running = false
        }
        if sapphire_sdl2_is_key_down(window, 41) {  // ESC
            running = false
        }
        
        // Input - Player 1 (W/S)
        if sapphire_sdl2_is_key_down(window, 26) {  // W
            paddle1_y = paddle1_y - paddle_speed
        }
        if sapphire_sdl2_is_key_down(window, 22) {  // S
            paddle1_y = paddle1_y + paddle_speed
        }
        
        // Input - Player 2 (Up/Down)
        if sapphire_sdl2_is_key_down(window, 82) {  // Up
            paddle2_y = paddle2_y - paddle_speed
        }
        if sapphire_sdl2_is_key_down(window, 81) {  // Down
            paddle2_y = paddle2_y + paddle_speed
        }
        
        // Clamp paddles
        if paddle1_y < 0 {
            paddle1_y = 0
        }
        if paddle1_y > 500 {
            paddle1_y = 500
        }
        if paddle2_y < 0 {
            paddle2_y = 0
        }
        if paddle2_y > 500 {
            paddle2_y = 500
        }
        
        // Move ball
        ball_x = ball_x + ball_dx
        ball_y = ball_y + ball_dy
        
        // Ball collision with top/bottom
        if ball_y < 0 {
            ball_y = 0
            ball_dy = 0 - ball_dy
        }
        if ball_y > 585 {
            ball_y = 585
            ball_dy = 0 - ball_dy
        }
        
        // Ball collision with paddles
        // Left paddle
        if ball_x < 30 {
            if ball_y > paddle1_y {
                if ball_y < paddle1_y + paddle_height {
                    ball_x = 30
                    ball_dx = 0 - ball_dx
                }
            }
        }
        
        // Right paddle
        if ball_x > 755 {
            if ball_y > paddle2_y {
                if ball_y < paddle2_y + paddle_height {
                    ball_x = 755
                    ball_dx = 0 - ball_dx
                }
            }
        }
        
        // Score - ball out of bounds
        if ball_x < 0 {
            score2 = score2 + 1
            ball_x = 400
            ball_y = 300
            ball_dx = 3
            ball_dy = 3
            print("Player 2 scores! Score:", score1, "-", score2)
        }
        if ball_x > 800 {
            score1 = score1 + 1
            ball_x = 400
            ball_y = 300
            ball_dx = 0 - 3
            ball_dy = 3
            print("Player 1 scores! Score:", score1, "-", score2)
        }
        
        // Render
        sapphire_sdl2_clear(window, 0, 0, 0)  // Black background
        
        // Draw center line
        sapphire_sdl2_fill_rect(window, 398, 0, 4, 600, 100, 100, 100)
        
        // Draw paddles (white)
        sapphire_sdl2_fill_rect(window, 10, paddle1_y, paddle_width, paddle_height, 255, 255, 255)
        sapphire_sdl2_fill_rect(window, 775, paddle2_y, paddle_width, paddle_height, 255, 255, 255)
        
        // Draw ball (white)
        sapphire_sdl2_fill_rect(window, ball_x, ball_y, ball_size, ball_size, 255, 255, 255)
        
        sapphire_sdl2_present(window)
        sapphire_sdl2_delay(16)  // ~60 FPS
    }
    
    sapphire_sdl2_destroy_window(window)
    print()
    print("Final Score:", score1, "-", score2)
    print("Thanks for playing!")
}
