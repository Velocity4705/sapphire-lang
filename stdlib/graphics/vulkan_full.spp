        # Begin render pass
        pass
    
    # End frame rendering
    fn end_frame(swapchain):
        # End render pass
        # End command buffer
        # Submit command buffer
        # Present image
        pass
    
    # Draw a simple triangle
    fn draw_triangle(device):
        # Bind pipeline
        # Bind vertex buffer
        # Draw 3 vertices
        pass
    
    # Wait for device to be idle
    fn device_wait_idle(device):
