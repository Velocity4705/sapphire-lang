# Arithmetic benchmark - Sapphire
# Tests: addition, multiplication, power operations

let a = 123456
let b = 789012
let c = 0

# Test 1: Addition chain
c = a + b
c = c + a
c = c + b
c = c + a
c = c + b
c = c + a
c = c + b
c = c + a
c = c + b
c = c + a

# Test 2: Multiplication chain
c = a * b
c = c * 2
c = c * 3
c = c * 4
c = c * 5

# Test 3: Power operations
c = 2 ** 10
c = 2 ** 15
c = 2 ** 20

# Test 4: Mixed operations
c = (a + b) * (a - b)
c = c + (a * b)
c = c - (a / 2)

print(c)
