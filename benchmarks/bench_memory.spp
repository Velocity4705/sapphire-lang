# Memory operations benchmark - Sapphire
# Tests: variable assignments and memory access

let x1 = 100
let x2 = 200
let x3 = 300
let x4 = 400
let x5 = 500

# Multiple assignments
let y1 = x1 + x2
let y2 = x2 + x3
let y3 = x3 + x4
let y4 = x4 + x5
let y5 = x5 + x1

# Chained operations
let z1 = y1 + y2 + y3
let z2 = y2 + y3 + y4
let z3 = y3 + y4 + y5

# Final computation
let result = z1 + z2 + z3

print(result)
